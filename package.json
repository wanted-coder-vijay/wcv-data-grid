{
  "name": "@wcv/data-grid",
  "version": "0.1.0",
  "description": "Enterprise-grade React DataGrid on TanStack + Radix + Tailwind, with operator-driven filters, inline editing, column pinning/resizing/reordering, CSV/Excel export, and full theme + i18n customization.",
  "license": "MIT",
  "author": "wanted-coder-vijay <drop.at.vijay@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wanted-coder-vijay/data-grid.git"
  },
  "homepage": "https://github.com/wanted-coder-vijay/data-grid#readme",
  "bugs": {
    "url": "https://github.com/wanted-coder-vijay/data-grid/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-content": "./dist/tailwind-content.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "react",
    "data-table",
    "tanstack-table",
    "shadcn",
    "radix",
    "tailwind",
    "ag-grid",
    "filters",
    "editable",
    "export"
  ],
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3"
  }
}
